    "@anthropic-ai/sdk": "^0.104.1",
    "@browserbasehq/stagehand": "^3.5.0",
    "@mindstudio-ai/agent": "^0.1.66",
    "ai": "^6.0.204",
    "axios": "^1.17.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express-cors": "^0.0.3",
    "next": "^16.2.9",
    "puppeteer": "^25.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.2.0",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.21.0",
    "happy-dom": "^20.10.2",
    "postcss": "^8.5.15",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^4.1.8"
  }
}
