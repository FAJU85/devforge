{
  "name": "devforge",
  "version": "1.0.0",
  "description": "--- title: DevForge emoji: ⚡ colorFrom: green colorTo: blue sdk: docker pinned: false license: mit ---",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:unit": "vitest",
    "test:unit:run": "vitest --run",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --run --coverage",
    "test:integration": "vitest tests/integration",
    "test:integration:run": "vitest --run tests/integration",
    "test:ui": "vitest tests/ui",
    "test:ui:run": "vitest --run tests/ui",
    "test:component": "vitest tests/components",
    "test:component:run": "vitest --run tests/components",
    "test:qa": "./qa/run_qa_suite.sh all",
    "test:qa:smoke": "./qa/run_qa_suite.sh smoke",
    "test:qa:selenium": "./qa/run_qa_suite.sh selenium",
    "test:selenium": "cd qa && pytest selenium/ -v",
    "test:allure": "allure serve allure-results",
    "qa:scan": "node qa/pattern_detector.js scan ./src",
    "qa:patterns": "node qa/pattern_detector.js list-patterns",
    "test:all": "node scripts/run-all-tests.js",
    "qa:learn": "node scripts/analyze-failures.js learn",
    "qa:failures": "node scripts/analyze-failures.js list",
    "qa:failures:stats": "node scripts/analyze-failures.js stats",
    "qa:failures:demo": "node scripts/analyze-failures.js demo",
    "qa:failures:collect": "node scripts/analyze-failures.js collect",
    "qa:failures:clear": "node scripts/analyze-failures.js clear",
    "qa:report": "node scripts/analyze-failures.js report",
    "qa:suggest": "node scripts/analyze-failures.js suggest",
    "qa:dashboard": "node scripts/dashboard.js",
    "qa:cron": "node scripts/cron-learn.js",
    "qa:cron:hourly": "node scripts/cron-learn.js --interval 3600000",
    "qa:cron:daily": "node scripts/cron-learn.js --interval 86400000",
    "test:generate": "npx ts-node tests/generators/generate-tests.ts",
    "test:generate:test": "npx ts-node tests/generators/generate-tests.ts --type test",
    "test:generate:data": "npx ts-node tests/generators/generate-tests.ts --type data",
    "test:self-heal": "npx playwright test tests/generated/self-healing-example.spec.ts",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "analyze:uiux": "npx tsx scripts/uiux-analyzer.ts"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:46329/git/FAJU85/devforge"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
