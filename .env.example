# DevForge Production Environment Configuration

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://devforge:devforge@postgres:5432/devforge
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
SQLALCHEMY_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0

# API Configuration
ALLOWED_ORIGINS=https://devforge.app,https://www.devforge.app,http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000

# Security
ENCRYPTION_KEY=generate_with_python_cryptography_fernet
RATELIMIT_ENABLED=true

# LLM Providers
ANTHROPIC_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_TOKEN=

# OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Monitoring & Observability
SENTRY_DSN=
ROLLBAR_ACCESS_TOKEN=
ROLLBAR_ENVIRONMENT=production
POSTHOG_API_KEY=

# Feature Flags
ENABLE_PROMETHEUS=true
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true
