{
  "name": "devforge-qa-extended",
  "version": "2.0.0",
  "description": "DevForge QA Suite with AI Agents and Browser Automation",
  "scripts": {
    "install:qa": "bash scripts/install-qa-extended.sh",
    "start:agents": "node api/agents_server.js",
    "start:browser": "node api/browser_server.js",
    "test:agents": "playwright test tests/agents/",
    "test:browser": "playwright test tests/browser/",
    "dev:agents": "nodemon api/agents_server.js",
    "qa:browser-agent": "python ml/agents/browser_agent.py",
    "qa:test-generator": "python ml/agents/test_generator_agent.py",
    "qa:bug-detector": "python ml/agents/bug_detector_agent.py"
  },
  "dependencies": {
    "ai": "^3.0.0",
    "@browserbasehq/stagehand": "^1.0.0",
    "puppeteer": "^21.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "nodemon": "^3.0.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0"
  },
  "optionalDependencies": {
    "chrome-remote-interface": "^0.31.0",
    "puppeteer-extra": "^3.3.0"
  }
}
